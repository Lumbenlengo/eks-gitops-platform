#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# bootstrap.sh - Infrastructure Provisioning Script
# This script automates the creation of the Terraform backend and 
# provisions the EKS cluster in stages to ensure dependency integrity.
# ---------------------------------------------------------------------------

set -euo pipefail

# ANSI Color Codes for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log()  { echo -e "${BLUE}[$(date +%H:%M:%S)]${NC} $1"; }
ok()   { echo -e "${GREEN}[$(date +%H:%M:%S)] ✓${NC} $1"; }
warn() { echo -e "${YELLOW}[$(date +%H:%M:%S)] ⚠${NC} $1"; }
fail() { echo -e "${RED}[$(date +%H:%M:%S)] ✗${NC} $1"; exit 1; }

# ---------------------------------------------------------------------------
# 0. Pre-flight Checks
# ---------------------------------------------------------------------------
log "Checking prerequisites..."

command -v aws       >/dev/null 2>&1 || fail "AWS CLI not found. Please install it."
command -v terraform >/dev/null 2>&1 || fail "Terraform not found. Please install it."
command -v kubectl   >/dev/null 2>&1 || fail "kubectl not found. Please install it."
command -v helm      >/dev/null 2>&1 || fail "helm not found. Please install it."

ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
REGION=$(aws configure get region || echo "us-east-1")
log "Target Account ID: ${ACCOUNT_ID} | Region: ${REGION}"

# Check for uninitialized placeholders in tfvars
if grep -q "REPLACE_WITH_YOUR_ACCOUNT_ID" terraform/terraform.tfvars 2>/dev/null; then
  fail "terraform.tfvars still contains placeholder values. Please update it before continuing."
fi

ok "Prerequisites verified."

# ---------------------------------------------------------------------------
# 1. Terraform Remote Backend Setup (S3 + DynamoDB)
# ---------------------------------------------------------------------------
BUCKET_NAME="lt-lumbe-tfstate-${ACCOUNT_ID}"
LOCK_TABLE="terraform-state-lock"

log "Provisioning S3 Bucket for Terraform Remote State..."
if aws s3 ls "s3://${BUCKET_NAME}" 2>/dev/null; then
  warn "Bucket ${BUCKET_NAME} already exists — skipping creation."
else
  aws s3 mb "s3://${BUCKET_NAME}" --region "${REGION}"
  aws s3api put-bucket-versioning \
    --bucket "${BUCKET_NAME}" \
    --versioning-configuration Status=Enabled
  aws s3api put-bucket-encryption \
    --bucket "${BUCKET_NAME}" \
    --server-side-encryption-configuration \
    '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
  aws s3api put-public-access-block \
    --bucket "${BUCKET_NAME}" \
    --public-access-block-configuration \
    "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"
  ok "S3 Bucket created: ${BUCKET_NAME}"
fi

log "Provisioning DynamoDB Table for State Locking..."
if aws dynamodb describe-table --table-name "${LOCK_TABLE}" --region "${REGION}" 2>/dev/null; then
  warn "Table ${LOCK_TABLE} already exists — skipping creation."
else
  aws dynamodb create-table \
    --table-name "${LOCK_TABLE}" \
    --attribute-definitions AttributeName=LockID,AttributeType=S \
    --key-schema AttributeName=LockID,KeyType=HASH \
    --billing-mode PAY_PER_REQUEST \
    --region "${REGION}"
  ok "DynamoDB Table created: ${LOCK_TABLE}"
fi

# Update backend.tf with the current Account ID
# This ensures Terraform knows exactly where to store the state file.
sed -i "s/lt-lumbe-tfstate-ACCOUNT_ID/lt-lumbe-tfstate-${ACCOUNT_ID}/g" \
  terraform/backend.tf

# ---------------------------------------------------------------------------
# 2. Terraform Initialization
# ---------------------------------------------------------------------------
log "Initializing Terraform..."
cd terraform
terraform init -upgrade
ok "Terraform initialized successfully."

# ---------------------------------------------------------------------------
# 3. Phased Terraform Apply (Handling dependencies gracefully)
# ---------------------------------------------------------------------------
log "Phase 1/4: Provisioning Network Infrastructure (VPC & Subnets)..."
terraform apply -target=module.networking -auto-approve
ok "Networking infrastructure ready."

log "Phase 2/4: Provisioning EKS Cluster (This may take 12-15 minutes)..."
terraform apply -target=module.eks -auto-approve
ok "EKS Cluster provisioned."

log "Phase 3/4: Provisioning IRSA & Add-ons (ALB Controller, KEDA, External Secrets)..."
terraform apply -target=module.irsa -auto-approve
terraform apply -target=module.addons -auto-approve
ok "Cloud Identity (IRSA) and Kubernetes Add-ons ready."

log "Phase 4/4: Deploying ArgoCD, Prometheus, and Namespaces..."
terraform apply -auto-approve
ok "Full stack deployment complete."

# ---------------------------------------------------------------------------
# 4. Post-Deployment: Kubectl Configuration
# ---------------------------------------------------------------------------
CLUSTER_NAME=$(terraform output -raw cluster_name 2>/dev/null || echo "eks-gitops-platform")
log "Updating kubeconfig for cluster: ${CLUSTER_NAME}..."
aws eks update-kubeconfig \
  --name "${CLUSTER_NAME}" \
  --region "${REGION}"
ok "kubectl context updated."

# ---------------------------------------------------------------------------
# 5. Health Checks
# ---------------------------------------------------------------------------
log "Waiting for core services to become healthy..."

kubectl wait --for=condition=ready pod \
  -l app.kubernetes.io/name=argocd-server \
  -n argocd \
  --timeout=300s
ok "ArgoCD Server is healthy."

kubectl wait --for=condition=ready pod \
  -l app=kube-prometheus-stack-prometheus \
  -n monitoring \
  --timeout=300s
ok "Prometheus Stack is healthy."

# ---------------------------------------------------------------------------
# 6. Deployment Summary & Next Steps
# ---------------------------------------------------------------------------
echo ""
echo -e "${GREEN}============================================================${NC}"
echo -e "${GREEN} Bootstrap Complete! Your Platform is Live.${NC}"
echo -e "${GREEN}============================================================${NC}"
echo ""
echo -e "${BLUE}Terraform Outputs (Required for GitOps Apps):${NC}"
terraform output
echo ""
echo -e "${BLUE}Access Gateways:${NC}"

ARGOCD_URL=$(kubectl get ingress -n argocd -o jsonpath='{.items[0].status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo "Pending...")
echo "  ArgoCD URL: https://${ARGOCD_URL}"
echo "  Username:   admin"
echo "  Password:   (As defined in your terraform.tfvars)"

echo ""
GRAFANA_URL=$(kubectl get ingress -n monitoring -o jsonpath='{.items[0].status.loadBalancer.ingress[0].hostname}' 2>/dev/null || echo "Pending...")
echo "  Grafana URL: https://${GRAFANA_URL}"
echo "  Username:    admin"
echo "  Password:    (As defined in your terraform.tfvars)"

echo ""
echo -e "${YELLOW}Next Steps — Deploy the GitOps Application manifests:${NC}"
echo "  kubectl apply -f ../argocd/projects/eks-gitops-platform.yaml"
echo "  kubectl apply -f ../argocd/apps/api-service.yaml"
echo "  kubectl apply -f ../argocd/apps/worker-service.yaml"

echo ""
echo -e "${YELLOW}Configure GitHub Secrets for CI/CD:${NC}"
echo "  ECR_API_REPO:      $(terraform output -raw ecr_api_service_url 2>/dev/null || echo 'check terraform output')"
echo "  ECR_WORKER_REPO:   $(terraform output -raw ecr_worker_service_url 2>/dev/null || echo 'check terraform output')"
echo "  AWS_ROLE_ARN:      $(terraform output -raw github_actions_role_arn 2>/dev/null || echo 'check terraform output')"
echo ""

cd ..

